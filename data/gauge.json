{
  "type": "gaugeface",
  "style": {
    "width": "100%",
    "height": "100%",
    "padding": { "all": 6 }
  },
  "props": {
    "backgroundColor": 0,
    "title": "Scale Only"
  },
  "children": [
    {
      "type": "rectangle",
      "style": {
        "width": "100%",
        "height": "100%",
        "padding": { "all": 8 },
        "flex": { "justify": "center", "align": "center" }
      },
      "props": {
        "radius": 10,
        "color": { "fill": 6470, "stroke": 9771, "thickness": 1 }
      },
      "children": [
        {
          "type": "circular-scale",
          "style": "inherit",
          "props": {
            "radius": 0.8,

            "startAngle": -135,
            "endAngle": 135,
            "value": {
              "id": "engineRPM",
              "min": 0,
              "max": 8000,
              "unitIndex": 0
            },

            "ticks": {
              "offset": 0,
              "root": {
                "useDivisions": true,
                "divisions": 8,
                "length": 18,
                "thickness": 3,
                "color": {
                  "fill": [
                    { "position": 0.0, "color": 65535 }
                  ],
                  "stroke": [
                    { "position": 0.0, "color": 0 }
                  ],
                  "thickness": 1
                }
              },
              "subs": []
            }
          },
          "children": [
            {
              "type": "circular-needle",
              "style": "inherit",
              "props": {
                "radius": 1.0,
                "color": {
                  "fill": 65535
                }
              }
            }
          ]
        }
      ]
    }
  ]
}
