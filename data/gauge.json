{
  "type": "gaugeface",
  "style": {
    "width": "100%",
    "height": "100%",
    "padding": { "all": 6 }
  },
  "props": {
    "backgroundColor": "#000000",
    "title": "Scale Only"
  },
  "children": [
    {
      "type": "rectangle",
      "style": {
        "width": "100%",
        "height": "100%",
        "padding": { "all": 8 },
        "flex": { "justify": "center", "align": "center" }
      },
      "props": {
        "radius": 10,
        "color": { "fill": "#192831", "stroke": "#21c65a", "thickness": 1 }
      },
      "children": [
        {
          "type": "circular-scale",
          "style": "inherit",
          "props": {
            "radius": 0.8,
            "startAngle": -135,
            "endAngle": 135,
            "value": {
              "id": "engineRPM",
              "min": 0,
              "max": 8000,
              "unitIndex": 0
            },
            "ticks": {
              "offset": 0,
              "root": {
                "useDivisions": true,
                "divisions": 8,
                "length": 10,
                "thickness": 3,
                "color": {
                  "fill": [
                    { "position": 0.0, "color": "#ffffff" }
                  ],
                  "stroke": [
                    { "position": 0.0, "color": "#000000" }
                  ],
                  "thickness": 1
                }
              },
              "subs": [
                {
                  "divisions": 4,
                  "thickness": 2,
                  "length": 5
                }
              ]
            }
          },
          "children": [
            {
              "type": "circular-needle",
              "style": "inherit",
              "props": {
                "radius": 0.5,
                "color": {
                  "fill": "green"
                }
              }
            }
          ]
        }
      ]
    }
  ]
}
