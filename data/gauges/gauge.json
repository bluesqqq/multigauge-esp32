{
  "type": "gaugeface",
  "style": {
    "width": "100%",
    "height": "100%",
    "padding": { "all": 12 },
    "flex": { "direction": "column", "justify": "center", "align": "center" },
    "gap": { "row": 10, "column": 10 }
  },
  "props": {
    "backgroundColor": "purple",
    "title": "Complex Test"
  },
  "children": [
    {
      "type": "rectangle",
      "style": {
        "width": "90%",
        "height": 80
      },
      "props": {
        "color": {
          "fill": "red",
          "stroke": "white",
          "thickness": 2
        },
        "radius": 8
      },
      "children": [
        {
          "type": "text",
          "style": {
            "width": "100%",
            "height": "100%"
          },
          "props": {
            "text": "Hello from Multigauge",
            "ellipses": true,
            "hyphens": false,
            "textPaint": {
              "family": "orbitron",
              "pt": 18,
              "weight": "bold",
              "slant": "normal",
              "color": "white"
            }
          }
        }
      ]
    },
    {
      "type": "circular-scale",
      "style": {
        "width": 220,
        "height": 220
      },
      "props": {
        "startAngle": 225,
        "endAngle": 315,
        "radius": 0.9,
        "value": { "id": "engineRPM", "min": 0, "max": 8000 },
        "ticks": {
          "offset": 0,
          "root": {
            "interval": 1000,
            "useDivisions": false,
            "length": 14,
            "thickness": 2,
            "color": {
              "fill": "white"
            },
            "valueStyle": {
              "spacing": 6,
              "flipValuesPosition": false,
              "textPaint": {
                "family": "sans",
                "pt": 12,
                "weight": "normal",
                "slant": "normal",
                "color": "white"
              }
            }
          },
          "subs": [
            {
              "divisions": 5,
              "length": 7,
              "thickness": 1,
              "color": { "fill": "grey" }
            }
          ]
        }
      }
    }
  ]
}