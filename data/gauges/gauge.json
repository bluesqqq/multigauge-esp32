{
  "$schema": "../../src/gauge.schema.json",
  "type": "gaugeface",
  "style": {
    "width": "100%",
    "height": "100%",
    "padding": { "all": 6 },
    "flex": { "align": "center", "justify": "center" }
  },
  "props": {
    "backgroundColor": "#000000",
    "title": "RPM Schematic"
  },
  "children": [
    {
      "type": "graph",
      "style": {
        "width": "70%",
        "height": "70%"
      },
      "props": {
        "seconds": 3,
        "backgroundColor": "#000000",
        "secondsColor": "red",
        "graphColor": "white",
        "borderColor": "white",
        "value": { "id": "engineRPM" }
      }
    }
  ]
}
